<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Painel Admin | Caio Ricson Advocacia</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="admin-body">
  <aside class="admin-sidebar">
    <div class="sidebar-logo">
      <span class="logo-nome">Caio Ricson</span>
      <span class="logo-sub">Painel</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="sidebar-link ativo">Dashboard</a>
      <a href="/" class="sidebar-link" target="_blank">Ver Site</a>
    </nav>
    <form action="/auth/logout" method="POST" class="sidebar-logout">
      <button type="submit" class="btn-logout">Sair</button>
    </form>
  </aside>

  <main class="admin-main">
    <div class="admin-topbar">
      <h1 class="admin-titulo">Painel Administrativo</h1>
      <span class="admin-usuario">Olá, <%= userName %></span>
    </div>

    <div class="dash-cards">
      <div class="dash-card">
        <span class="dash-card-num"><%= processos.length %></span>
        <span class="dash-card-label">Total de Processos</span>
      </div>
      <div class="dash-card">
        <span class="dash-card-num"><%= processos.filter(p => p.status === 'Em andamento').length %></span>
        <span class="dash-card-label">Em Andamento</span>
      </div>
      <div class="dash-card">
        <span class="dash-card-num"><%= processos.filter(p => p.status === 'Aguardando audiência').length %></span>
        <span class="dash-card-label">Aguardando Audiência</span>
      </div>
      <div class="dash-card">
        <span class="dash-card-num"><%= processos.filter(p => p.status === 'Encerrado').length %></span>
        <span class="dash-card-label">Encerrados</span>
      </div>
    </div>

    <div class="dash-graficos">
      <div class="dash-grafico-card">
        <p class="dash-grafico-titulo">Processos por Status</p>
        <canvas id="graficoStatus"></canvas>
      </div>
      <div class="dash-grafico-card">
        <p class="dash-grafico-titulo">Processos por Área</p>
        <canvas id="graficoArea"></canvas>
      </div>
    </div>

    <script>
      const statusLabels = ['Em andamento', 'Aguardando audiência', 'Em recurso', 'Encerrado'];
      const statusData = [
        <%= processos.filter(p => p.status === 'Em andamento').length %>,
        <%= processos.filter(p => p.status === 'Aguardando audiência').length %>,
        <%= processos.filter(p => p.status === 'Em recurso').length %>,
        <%= processos.filter(p => p.status === 'Encerrado').length %>
      ];

      const todosProcessos = <%- JSON.stringify(processos) %>;
      const todasAreas = [...new Set(todosProcessos.map(p => p.area))];
      const areaData = todasAreas.map(area => todosProcessos.filter(p => p.area === area).length);

      const cores = ['#C9A84C', '#7ec8a0', '#e09070', '#888888'];

      new Chart(document.getElementById('graficoStatus'), {
        type: 'doughnut',
        data: {
          labels: statusLabels,
          datasets: [{ data: statusData, backgroundColor: cores, borderWidth: 0 }]
        },
        options: {
          plugins: {
            legend: { labels: { color: '#e8e0d0', font: { size: 12 } } }
          }
        }
      });

      new Chart(document.getElementById('graficoArea'), {
        type: 'bar',
        data: {
          labels: todasAreas.length ? todasAreas : ['Sem dados'],
          datasets: [{
            label: 'Processos',
            data: areaData.length ? areaData : [0],
            backgroundColor: '#C9A84C',
            borderRadius: 4
          }]
        },
        options: {
          plugins: { legend: { display: false } },
          scales: {
            x: { ticks: { color: '#888' }, grid: { color: 'rgba(255,255,255,0.05)' } },
            y: { ticks: { color: '#888', stepSize: 1 }, grid: { color: 'rgba(255,255,255,0.05)' }, beginAtZero: true }
          }
        }
      });
    </script>

    <h2 class="admin-subtitulo">Serviços</h2>

    <div class="admin-acoes">
      <a href="/admin/servicos/novo" class="btn btn-primario">+ Novo Serviço</a>
      <form action="/admin/servicos/buscar" method="GET" class="busca-form">
        <input type="text" name="q" placeholder="Buscar serviço..." value="<%= busca %>" class="busca-input">
        <button type="submit" class="btn btn-secundario">Buscar</button>
        <% if (busca) { %><a href="/admin" class="btn-limpar">Limpar</a><% } %>
      </form>
    </div>

    <% if (busca) { %>
      <p class="busca-resultado">Resultados para "<%= busca %>": <%= servicos.length %> encontrado(s)</p>
    <% } %>

    <div class="admin-tabela-wrap">
      <table class="admin-tabela">
        <thead>
          <tr><th>Título</th><th>Área</th><th>Descrição</th><th>Ações</th></tr>
        </thead>
        <tbody>
          <% if (servicos.length === 0) { %>
            <tr><td colspan="4" class="sem-resultados">Nenhum serviço encontrado.</td></tr>
          <% } %>
          <% servicos.forEach(s => { %>
          <tr>
            <td><strong><%= s.titulo %></strong></td>
            <td><span class="badge-area"><%= s.area %></span></td>
            <td class="td-desc"><%= s.descricao.substring(0, 80) %>...</td>
            <td class="td-acoes">
              <a href="/admin/servicos/editar/<%= s.id %>" class="btn-tabela btn-editar">Editar</a>
              <form action="/admin/servicos/excluir/<%= s.id %>" method="POST" style="display:inline" onsubmit="return confirm('Excluir este serviço?')">
                <button type="submit" class="btn-tabela btn-excluir">Excluir</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <h2 class="admin-subtitulo">Processos (<%= processos.length %>)</h2>

    <div class="admin-acoes">
      <a href="/admin/processos/novo" class="btn btn-primario">+ Novo Processo</a>
    </div>

    <div class="admin-tabela-wrap">
      <table class="admin-tabela">
        <thead>
          <tr><th>Nº Processo</th><th>Cliente</th><th>Área</th><th>Status</th><th>Audiência</th><th>Ações</th></tr>
        </thead>
        <tbody>
          <% if (processos.length === 0) { %>
            <tr><td colspan="6" class="sem-resultados">Nenhum processo cadastrado.</td></tr>
          <% } %>
          <% processos.forEach(p => { %>
          <tr>
            <td style="color: var(--dourado); font-size:13px"><%= p.numero %></td>
            <td><strong><%= p.cliente_nome %></strong></td>
            <td><span class="badge-area"><%= p.area %></span></td>
            <td><span class="badge-status badge-status--<%= p.status.toLowerCase().replace(/ /g, '-') %>"><%= p.status %></span></td>
            <td style="font-size:13px; color: var(--cinza)">
              <% if (p.proxima_audiencia) { %>
                <%= new Date(p.proxima_audiencia + 'T12:00:00').toLocaleDateString('pt-BR') %>
              <% } else { %>A definir<% } %>
            </td>
            <td class="td-acoes">
              <a href="/admin/processos/<%= p.id %>/mensagens" class="btn-tabela btn-editar">Mensagens</a>
              <a href="/admin/processos/editar/<%= p.id %>" class="btn-tabela btn-editar">Editar</a>
              <form action="/admin/processos/excluir/<%= p.id %>" method="POST" style="display:inline" onsubmit="return confirm('Excluir este processo?')">
                <button type="submit" class="btn-tabela btn-excluir">Excluir</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="admin-contatos">
      <h2 class="admin-subtitulo">Mensagens de Contato (<%= contatos.length %>)</h2>
      <% if (contatos.length === 0) { %>
        <p class="sem-resultados">Nenhuma mensagem recebida ainda.</p>
      <% } else { %>
        <div class="contatos-lista">
          <% contatos.forEach(c => { %>
          <div class="contato-card">
            <div class="contato-card-header">
              <strong><%= c.nome %></strong>
              <span class="contato-data"><%= new Date(c.recebido_em).toLocaleDateString('pt-BR') %></span>
            </div>
            <p class="contato-email"><%= c.email %><% if (c.telefone) { %> · <%= c.telefone %><% } %></p>
            <p class="contato-msg"><%= c.mensagem %></p>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </main>
</body>
</html>
